# --- Supabase ---
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose to the client. Used for admin/back-office tasks only —
# normal MCP requests are validated against the user's own token via JWKS, not this.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- MCP server ---
# Public URL of the MCP endpoint, used in OAuth Protected Resource Metadata
# (must match what users paste into claude.ai "Add connector").
MCP_SERVER_URL=http://localhost:3000/api/mcp
